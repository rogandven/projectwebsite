---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Home/Hero.astro';
import InfoCardContainer from '../components/Home/InfoCard/InfoCardContainer.astro';
import ButtonInfo from '../classes/ButtonInfo.ts';
import CardInfo from '../classes/CardInfo.ts';
import { BLOG_ADDRESS, COLOR_PRIMARY, COLOR_SECONDARY, INDEX_PREFIX } from '../constants/DefaultValueConstants.ts';
import { BLOG_ICON_NAME, APP_FEATURES_ICON_NAME } from '../constants/IconConstants.ts';
import { getFeaturesURL } from '../utils/GeneralUtils.ts';

const BUTTON_ARRAY: ButtonInfo[] = [
    new ButtonInfo(APP_FEATURES_ICON_NAME, getFeaturesURL(Astro), COLOR_PRIMARY, "Ver Características", "", false),
    new ButtonInfo(BLOG_ICON_NAME, BLOG_ADDRESS, COLOR_SECONDARY, "Ver Blog", "", false),
];

const CARD_INFO_ARRAY: CardInfo[] = [
    new CardInfo("mdi:language-php", "Nueva versión de PHP", 
                `${INDEX_PREFIX} serán migradas de PHP 5.4 a PHP 8.2, la cual incluye varias mejoras de seguridad, 
                seguirá recibiendo soporte en 2026 y actualiza su funcionalidad a los estándares modernos.`
    ),
    new CardInfo("mdi:email-send-outline", "Mejor interoperabilidad", 
                `${INDEX_PREFIX} ofreceran mejor interoperabilidad con la API de Mercado Público.`
    ),
    new CardInfo("mdi:security", "Validaciones de datos robustas", 
                `${INDEX_PREFIX} ofreceran mejor validación de datos tanto en el cliente como en el 
                servidor, lo que agiliza el proceso de rellenar los formularios necesarios, 
                además de mejorar la seguridad general de la aplicación.`
    ),
    new CardInfo("mdi:paint-outline", "Rediseño visual", 
                `${INDEX_PREFIX} se ajustarán a los estándares de rediseño visual vigentes, establecidos 
                por el equipo de Transformación Digital de la Universidad del Bío-Bío.`
    ),    
    new CardInfo("mdi:accessibility", "Accesibilidad", 
                `${INDEX_PREFIX} se ajustarán a los estándares de accesibilidad vigentes, 
                establecidos por el equipo de Transformación Digital de la Universidad del Bío-Bío.`
    ),
    new CardInfo("mdi:legal", "Cumplimiento Legal", 
                `${INDEX_PREFIX} seguirán las restricciones establecidas por las leyes 19.886 y 21.180, 
                que restringen la forma en que deben gestionarse las compras a agentes externos en 
                entornos digitales en Chile.`
    ),             
];
---

<Layout title="Inicio">
    <Hero 
        title='Sistema de Compra de Materiales por Mercado Público para la intranet de la Universidad del Bío-Bío'
        description='Los módulos de intranet de 
        la Universidad del Bío-Bío se encuentran 
        actualmente en proceso de migración de 
        la versión actual de sí mismos, a una 
        versión mejorada en desarrollo de ellos, 
        y el sistema de solicitud de compras a 
        Mercado Público no es la excepción.'
        buttons={BUTTON_ARRAY}
    />
    <InfoCardContainer cards={CARD_INFO_ARRAY}/>
</Layout>
