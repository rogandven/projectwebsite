---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Home/Hero.astro';
import InfoCardContainer from '../components/Home/InfoCard/InfoCardContainer.astro';
import ButtonInfo from '../classes/ButtonInfo.ts';
import { BLOG_ADDRESS, COLOR_PRIMARY, COLOR_SECONDARY } from '../constants/DefaultValueConstants.ts';
import { BLOG_ICON_NAME, APP_FEATURES_ICON_NAME } from '../constants/IconConstants.ts';
import { getFeaturesURL } from '../utils/GeneralUtils.ts';

const BUTTON_ARRAY: ButtonInfo[] = [
    new ButtonInfo(APP_FEATURES_ICON_NAME, getFeaturesURL(Astro), COLOR_PRIMARY, "Ver Características", "", false),
    new ButtonInfo(BLOG_ICON_NAME, BLOG_ADDRESS, COLOR_SECONDARY, "Ver Blog", "", false),
];
---

<Layout title="Inicio">
    <Hero 
        title='Sistema de Compra de Materiales por Mercado Público para la intranet de la Universidad del Bío-Bío'
        description='Los módulos de intranet de 
        la Universidad del Bío-Bío se encuentran 
        actualmente en proceso de migración de 
        la versión actual de sí mismos, a una 
        versión mejorada en desarrollo de ellos, 
        y el sistema de solicitud de compras a 
        Mercado Público no es la excepción.'
        buttons={BUTTON_ARRAY}
    />
    <InfoCardContainer />
</Layout>
