---
import { AstroDevToolbar } from "astro/runtime/client/dev-toolbar/toolbar.js";
import BlogBase from "../components/Blog/BlogBase.astro";
import PostData from "../components/Blog/PostData.astro";
import GoBackButton from "../components/Buttons/GoBackButton.astro";
import { getGoBackURL, getPostInfo } from "../utils/GeneralUtils";
import Layout from "./Layout.astro";

const { frontmatter } = Astro.props;
const goBackURL: string = getGoBackURL(Astro, 2);
---
<Layout title={frontmatter.title}>
    <BlogBase>
        <ul class="list">
            <li class="list-row">
                <GoBackButton buttonUrl={goBackURL} />
            </li>
            <li class="list-row">
                <div>
                    <PostData classes="mb-2" post={getPostInfo({frontmatter: frontmatter})} />
                    <p class="mt-2">{frontmatter?.description}</p>
                </div>
            </li>
            <li class="list-row">
                <div class="
                    prose
                    prose-headings:m-0
                    prose-headings:mb-2
                    prose-headings:font-bold
                    prose-headings:text-primary
                    prose-p:m-0 
                    prose-p:mb-2
                ">
                    <slot></slot>
                </div>
            </li>
            <li class="list-row">
                <GoBackButton buttonUrl={goBackURL} />
            </li>            
        </ul>
    </BlogBase>
</Layout>