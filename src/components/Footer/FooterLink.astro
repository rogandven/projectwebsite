---
import { Icon } from "astro-icon/components";
import { DEFAULT_ICON_NAME, DEFAULT_LINK } from "../../constants/DefaultValueConstants.ts";
import { getAbsoluteURL } from "../../utils/GeneralUtils.ts";

interface Props {
    iconName?: string;
    destination?: string;
}

const { 
    iconName = DEFAULT_ICON_NAME,
    destination = DEFAULT_LINK
} = Astro.props;
---

<a href={getAbsoluteURL(Astro, destination)} target="_blank">
    <Icon name={iconName} class="text-2xl" />
</a>