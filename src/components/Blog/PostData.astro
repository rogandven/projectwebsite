---
import { Icon } from "astro-icon/components";
import { DEFAULT_ICON_NAME } from "../../constants/IconConstants.ts";
import { MIDDLE_ALIGNER, DARKER_TEXT } from "../../constants/TailwindConstants.ts";
import PostInfo from "../../classes/PostInfo.ts";
import { getAbsoluteURL } from "../../utils/GeneralUtils.ts";
import { getAuthorImage } from "../../utils/ImageUtils.ts";

interface Props {
    post?: PostInfo,
    classes?: string
}

const { 
    post = new PostInfo(),
    classes = "",
} = Astro.props;
---
<div class={classes}>
    <a href={getAbsoluteURL(Astro, post.URL, true)}><h2 class="text-2xl font-bold mb-2">{post.title}</h2></a>
    <div class={MIDDLE_ALIGNER}>
        <img class="size-10 rounded-full mr-2" src={getAuthorImage(Astro, post.author)} alt={post.author}/>
        <div>
            <h3 class="text-base">{post.author}</h3>
            <div class={MIDDLE_ALIGNER}>
                <Icon class={DARKER_TEXT} name={DEFAULT_ICON_NAME} />
                <h4 class={DARKER_TEXT}>{post.date}</h4>
            </div>
            <p></p>
        </div>
    </div>
</div>