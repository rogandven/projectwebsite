---
import { Icon } from "astro-icon/components";
import { DEFAULT_ICON_NAME } from "../../constants/DefaultValueConstants.ts";
import { descriptionGenerator } from "../../utils/GeneralUtils.ts";
import PostInfo from "../../classes/PostInfo.ts";
import PostData from "./PostData.astro";

interface Props {
    post?: PostInfo,
}

const { 
    post = new PostInfo(),
} = Astro.props;
---

<div>
    <PostData post={post}/>
    <p class="mt-2">{descriptionGenerator(post.description)}</p>
    <a href={post.URL}>
        <button class="btn btn-primary mt-2">
            <Icon name={DEFAULT_ICON_NAME} />
            Leer
        </button>
    </a>
</div>