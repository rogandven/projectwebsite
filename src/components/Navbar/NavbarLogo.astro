---
import { Icon } from "astro-icon/components";
import { DEFAULT_APPLICATION_NAME } from "../../constants/DefaultValueConstants.ts";
import { DEFAULT_HALFSIDEMARGIN, NAVBAR_LEFTSIDE_CLASS } from "../../constants/TailwindConstants.ts";
import { getTrueHomeURL } from "../../utils/GeneralUtils.ts";
import { APP_ICON_NAME } from "../../constants/IconConstants.ts";
---

<div class={NAVBAR_LEFTSIDE_CLASS}>
    <a class={"btn btn-primary btn-ghost text-base-100 text-xl " + DEFAULT_HALFSIDEMARGIN} href={getTrueHomeURL(Astro)}>
        <Icon name={APP_ICON_NAME} />
        {DEFAULT_APPLICATION_NAME}
    </a>
</div>