---
import { BLOG_ADDRESS } from "../../constants/DefaultValueConstants.ts";
import { getFeaturesURL } from "../../utils/GeneralUtils.ts";
import NavbarBody from "./NavbarBody.astro";
import NavbarLink from "./NavbarLink.astro";
import { APP_FEATURES_ICON_NAME, BLOG_ICON_NAME } from "../../constants/IconConstants.ts";
---

<NavbarBody>
    <NavbarLink name="Características" iconName={APP_FEATURES_ICON_NAME} destination={getFeaturesURL(Astro)}></NavbarLink>
    <NavbarLink name="Blog" iconName={BLOG_ICON_NAME} destination={BLOG_ADDRESS}></NavbarLink>
</NavbarBody>