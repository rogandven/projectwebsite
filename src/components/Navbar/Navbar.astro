---
import { BLOG_ADDRESS, BLOG_TEXT, FEATURES_TEXT } from "../../constants/DefaultValueConstants.ts";
import { getFeaturesURL } from "../../utils/GeneralUtils.ts";
import NavbarBody from "./NavbarBody.astro";
import NavbarLink from "./NavbarLink.astro";
import { APP_FEATURES_ICON_NAME, BLOG_ICON_NAME } from "../../constants/IconConstants.ts";
---

<NavbarBody>
    <NavbarLink name={BLOG_TEXT} iconName={BLOG_ICON_NAME} destination={BLOG_ADDRESS}></NavbarLink>
    <NavbarLink name={FEATURES_TEXT} iconName={APP_FEATURES_ICON_NAME} destination={getFeaturesURL(Astro)}></NavbarLink>
</NavbarBody>