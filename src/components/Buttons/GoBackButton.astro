---
import { DEFAULT_LINK } from "../../constants/DefaultValueConstants.ts";
import { RETURN_ICON_NAME } from "../../constants/IconConstants.ts";
import ButtonBase from "./ButtonBase.astro";

interface Props {
    buttonUrl?: string;
}

const { 
    buttonUrl = DEFAULT_LINK,
} = Astro.props;
---
<ButtonBase 
    iconName={RETURN_ICON_NAME} 
    destination={buttonUrl}
    text={"Volver"}
    color={"accent"}
    classes={""}
/>